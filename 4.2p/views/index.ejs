<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Movie Collection App</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="container">
    <header>
      <h1>Movie Collection Manager</h1>
      <p>A simple server-side app using Express, EJS and MongoDB.</p>
    </header>

    <% if (message) { %>
      <div class="message"><%= message %></div>
    <% } %>

    <section class="card">
      <h2>Add a New Movie</h2>
      <form action="/movies/add" method="POST" class="movie-form">
        <input type="text" name="title" placeholder="Movie title" required />
        <input type="text" name="genre" placeholder="Genre" required />
        <input type="number" name="releaseYear" placeholder="Release year" required />
        <input type="number" step="0.1" min="0" max="10" name="rating" placeholder="Rating (0-10)" required />
        <button type="submit">Add Movie</button>
      </form>
    </section>

    <section class="card">
      <h2>Saved Movies</h2>
      <% if (movies.length === 0) { %>
        <p>No movies found in the database yet.</p>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Rating</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% movies.forEach((movie) => { %>
                <tr>
                  <td><%= movie.title %></td>
                  <td><%= movie.genre %></td>
                  <td><%= movie.releaseYear %></td>
                  <td><%= movie.rating %></td>
                  <td>
                    <form action="/movies/delete/<%= movie._id %>" method="POST">
                      <button type="submit" class="delete-btn">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </div>
</body>
</html>
